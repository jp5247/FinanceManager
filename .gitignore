# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Node / Tauri
node_modules/
dist/
dist-ssr/
.vite/
src-tauri/target/
src-tauri/gen/schemas/

# TS incremental build artifacts (composite project refs)
*.tsbuildinfo
vite.config.d.ts
vite.config.js
vite.config.js.map

# IDE
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets/*
!secrets/README.md

# User data (must never be committed)
data/
**/data/users/

# Real bank PDFs contain PII — never commit, anywhere in the repo
*.pdf
*.PDF
# Spike output folders contain extracted text from real PDFs (PII)
spikes/**/out*/
spikes/**/fixtures-output*/
# Anonymized golden fixtures may be committed if explicitly opted in:
!docs/**/*.pdf
!**/fixtures/anonymized/*.pdf

# Build artifacts
*.exe
*.dll
*.dylib
*.so
!third_party/**/*.dll

# Vendored pdfium binaries (downloaded by developer, not committed)
pdfium-win-x64/
pdfium-mac-*/
pdfium-linux-*/
